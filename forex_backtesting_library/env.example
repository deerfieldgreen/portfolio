# Oanda API Configuration (v20 API; practice account, no account ID required)
OANDA_API_KEY=your_oanda_api_key_here

# ClickHouse Configuration (admin: for setup_database.py; app: use vectorbt_grid user after setup)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=your_password_here
CLICKHOUSE_DATABASE=vectorbt_grid
CLICKHOUSE_SECURE=false

# Password for the vectorbt_grid user (used by setup_database.py to create the user)
VECTORBT_GRID_USER_PASSWORD=your_vectorbt_grid_user_password

# Optional: Oanda environment (practice | live). Default: practice
# OANDA_ENVIRONMENT=practice
