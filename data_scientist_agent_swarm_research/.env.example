# ── Data Source ──
OANDA_PROXY_URL=http://oanda-cache:8080
OANDA_FETCH_RETRIES=3
OANDA_FETCH_BACKOFF_BASE=2.0

# ── ClickHouse ──
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=cervid_analytics

# ── MLflow ──
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=https://ams3.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MLFLOW_EXPERIMENT_NAME=fx-swarm

# ── Novita API ──
NOVITA_BASE_URL=https://api.novita.ai/v3/openai
NOVITA_API_KEY=
LLM_ANALYSIS_MODEL=qwen/qwen3.5-397b-a17b
LLM_ROUTING_MODEL=qwen/qwen3-32b-fp8
LLM_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
LLM_EMBEDDING_DIM=4096
LLM_EMBEDDING_BATCH_SIZE=10

# ── Training ──
EPOCHS=50
OPTUNA_TRIALS=20
SEQUENCE_LENGTH=60
TRAIN_WINDOW_MONTHS=8
VAL_WINDOW_MONTHS=2
TEST_WINDOW_MONTHS=2
BATCH_SIZE=64
EARLY_STOPPING_PATIENCE=10
LEARNING_RATE_MIN=0.0001
LEARNING_RATE_MAX=0.01

# ── Swarm ──
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=fx_experiments
QDRANT_RESEARCH_COLLECTION=fx_research
SWARM_BATCH_SIZE=4
EXPLORATION_BUDGET_PCT=0.20
CIRCUIT_BREAKER_THRESHOLD=50

# ── Promotion Gate ──
MIN_DIRECTIONAL_ACCURACY=0.52
MIN_OOS_PREDICTIONS=500
MAX_PBO=0.30
DSR_IMPROVEMENT_THRESHOLD=0.05
MAX_DRAWDOWN_TOLERANCE=1.10

# ── Notifications ──
DISCORD_WEBHOOK_URL=

# ── Research Crawl ──
TAVILY_API_KEY=

# ── Infrastructure ──
GPU_NODE_POOL=gpu-pool
CPU_NODE_POOL=ams3-digitalocean-cervid-amd-pool
ARGO_NAMESPACE=argo
S3_ARTIFACT_BUCKET=fx-swarm-artifacts
DRAGONFLY_URL=redis://dragonfly:6379/0
