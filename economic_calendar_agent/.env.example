# Economic Calendar Agent - Environment Variables

# FMP API Configuration
FMP_API_KEY=your_fmp_api_key_here
FMP_BASE_URL=https://financialmodelingprep.com/api/v3
FMP_RATE_LIMIT_PER_MIN=750

# ClickHouse Configuration
CLICKHOUSE_URL=clickhouse.cervid.deerfieldgreen.com
CLICKHOUSE_PORT=443
CLICKHOUSE_DATABASE=cervid_analytics
CLICKHOUSE_USERNAME=cervid
CLICKHOUSE_PASSWORD=

# Dragonfly Configuration (Redis-compatible)
DRAGONFLY_ENDPOINT=dragonfly.cervid.deerfieldgreen.com
DRAGONFLY_PORT=6379
DRAGONFLY_USERNAME=default
DRAGONFLY_PASSWORD=

# Qdrant Configuration
QDRANT_ENDPOINT=qdrant.cervid.deerfieldgreen.com
QDRANT_API_KEY=

# Novita LLM Configuration
NOVITA_API_KEY=your_novita_api_key_here
NOVITA_BASE_URL=https://api.novita.ai/v3/openai
NOVITA_LLM_MODEL=meta-llama/llama-3.1-70b-instruct
NOVITA_LLM_TEMPERATURE=0.1
NOVITA_LLM_MAX_TOKENS=2000

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# Trading Pairs (comma-separated)
TARGET_PAIRS=USDJPY,EURUSD,GBPUSD,AUDUSD

# Pipeline Configuration
PIPELINE_LOOKBACK_DAYS=90
PIPELINE_LOOKAHEAD_HOURS=48

# Cache Configuration
CACHE_TTL_SECONDS=36000
